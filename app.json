{
  "expo": {
    "name": "HackAthon",
    "slug": "HackAthon",
    "version": "1.0.0",
    "android": {
      "package": "com.bence1337.HackAthon",
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ]
  }
}
